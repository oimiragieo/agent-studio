{
  "pattern_id": "timeout-retry",
  "name": "Retry on Timeout with Exponential Backoff",
  "description": "Automatically retry operations that timeout with exponential backoff strategy. Suitable for transient network issues, temporary resource unavailability, or slow-responding services.",
  "version": "1.0.0",
  "enabled": true,
  "triggers": [
    {
      "condition": "timeout",
      "severity": "medium",
      "threshold": 1,
      "timeframe_minutes": 60
    }
  ],
  "strategy": "retry",
  "priority": 3,
  "tags": ["timeout", "retry", "network", "transient"],
  "applicable_agents": [],
  "retry_policy": {
    "max_attempts": 3,
    "backoff": "exponential",
    "delay_ms": 1000,
    "max_delay_ms": 60000,
    "timeout_multiplier": 1.5,
    "jitter": true,
    "jitter_factor": 0.1,
    "reset_on_success": true
  },
  "conditions": {
    "workflow_phase": ["implementation", "testing", "deployment"],
    "environment": ["development", "staging", "production"]
  },
  "metrics": {
    "success_rate_threshold": 0.7,
    "track_execution_time": true,
    "track_resource_usage": false
  },
  "metadata": {
    "created_by": "system",
    "created_at": "2025-01-15T00:00:00Z",
    "usage_count": 0,
    "success_count": 0,
    "failure_count": 0
  }
}
