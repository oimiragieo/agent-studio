  "features_implemented": {
    "recovery_dsl": {
      "strategies": [
        {
          "name": "retry",
          "backoff_types": ["fixed", "linear", "exponential"],
          "features": ["jitter", "timeout_multiplier", "max_attempts"]
        },
        {
          "name": "escalate",
          "features": [
            "escalation_chain",
            "timeout_multiplier",
            "priority_boost",
            "context_inclusion"
          ]
        },
        {
          "name": "skip",
          "features": [
            "impact_assessment",
            "alternative_steps",
            "approval_required",
            "workflow_degradation"
          ]
        },
        {
          "name": "rollback",
          "features": ["target_state", "cleanup", "restore_files", "notification"]
        },
        {
          "name": "halt",
          "features": ["cleanup", "state_preservation", "notifications", "incident_creation"]
        }
      ],
      "trigger_conditions": [
        "timeout",
        "test_failure",
        "compilation_error",
        "dependency_missing",
        "resource_unavailable",
        "validation_failure",
        "security_violation",
        "network_error",
        "authentication_failure",
        "rate_limit_exceeded",
        "disk_space_low",
        "memory_exhausted"
      ],
      "severity_levels": ["low", "medium", "high", "critical"],
      "pattern_matching": {
        "condition_matching": true,
        "severity_filtering": true,
        "error_pattern_regex": true,
        "threshold_counting": true,
        "timeframe_windowing": true
      }
    },
    "task_queue": {
      "concurrency_control": {
        "max_concurrent": 2,
        "auto_start": true,
        "capacity_enforcement": true
      },
      "priority_queue": {
        "levels": ["high", "medium", "low"],
        "sorting": ["priority", "creation_time"]
      },
      "dependency_management": {
        "dependency_declaration": true,
        "dependency_resolution": true,
        "circular_dependency_detection": false
      },
      "retry_policy": {
        "max_retries": true,
        "retry_delay": true,
        "automatic_retry": true
      },
      "state_persistence": {
        "save_on_change": true,
        "crash_recovery": true,
        "json_format": true
      }
    }
  },
  "cli_commands": {
    "recovery_handler": [
      "node .claude/tools/recovery-handler.mjs --test",
      "node .claude/tools/recovery-handler.mjs --apply --pattern <id> --failure <type>",
      "node .claude/tools/recovery-handler.mjs --match --failure <type> --severity <level>",
      "node .claude/tools/recovery-handler.mjs --list-patterns",
      "node .claude/tools/recovery-handler.mjs --stats"
    ],
    "task_queue": [
      "node .claude/tools/task-queue.mjs enqueue --run-id <id> --agent <type> --task <desc>",
      "node .claude/tools/task-queue.mjs complete --run-id <id> --task-id <uuid>",
      "node .claude/tools/task-queue.mjs fail --run-id <id> --task-id <uuid> --error <msg>",
      "node .claude/tools/task-queue.mjs cancel --run-id <id> --task-id <uuid>",
      "node .claude/tools/task-queue.mjs status --run-id <id> --task-id <uuid>",
      "node .claude/tools/task-queue.mjs stats --run-id <id>",
      "node .claude/tools/task-queue.mjs list --run-id <id>"
    ]
